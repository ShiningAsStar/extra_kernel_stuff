diff --git a/fs/proc/cmdline.c b/fs/proc/cmdline.c
--- a/fs/proc/cmdline.c
+++ b/fs/proc/cmdline.c
@@ -3,14 +3,34 @@
 #include <linux/init.h>
 #include <linux/proc_fs.h>
 #include <linux/seq_file.h>
+#include <linux/slab.h>
+#include <linux/string.h>
 
 static int cmdline_proc_show(struct seq_file *m, void *v)
 {
-	seq_puts(m, saved_command_line);
-	seq_putc(m, '\n');
+	char *c = kstrdup(saved_command_line, GFP_KERNEL);
+
+	if (c) {
+		char *s;
+
+		while ((s = strstr(c, "verifiedbootstate=orange")))
+			memcpy(s, "verifiedbootstate=green ", 24);
+		while ((s = strstr(c, "verifiedbootstate=red")))
+			memcpy(s, "verifiedbootstate=green", 23);
+		while ((s = strstr(c, "flash.locked=0")))
+			memcpy(s, "flash.locked=1", 14);
+		while ((s = strstr(c, "veritymode=logging")))
+			memcpy(s, "veritymode=enforcing", 20);
+		seq_puts(m, c);
+		kfree(c);
+	} else {
+		seq_puts(m, saved_command_line);
+	}
+
+	seq_putc(m, '\n');
 	return 0;
 }
 
 static int __init proc_cmdline_init(void)
 {
 	proc_create_single("cmdline", 0, NULL, cmdline_proc_show);
diff --git a/fs/proc/bootconfig.c b/fs/proc/bootconfig.c
--- a/fs/proc/bootconfig.c
+++ b/fs/proc/bootconfig.c
@@ -3,9 +3,31 @@
 #include <linux/init.h>
 #include <linux/proc_fs.h>
 #include <linux/seq_file.h>
+#include <linux/slab.h>
+#include <linux/string.h>
 
 static int bootconfig_proc_show(struct seq_file *m, void *v)
 {
+	char *b = kmalloc(bootconfig_data_size + 1, GFP_KERNEL);
+
+	if (b) {
+		char *s;
+
+		memcpy(b, bootconfig_data, bootconfig_data_size);
+		b[bootconfig_data_size] = '\0';
+		while ((s = strstr(b, "verifiedbootstate = \"orange\"")))
+			memcpy(s, "verifiedbootstate  = \"green\"", 27);
+		while ((s = strstr(b, "device_state = \"unlocked\"")))
+			memcpy(s, "device_state   = \"locked\"", 25);
+		while ((s = strstr(b, "flash.locked = \"0\"")))
+			memcpy(s, "flash.locked = \"1\"", 18);
+		while ((s = strstr(b, "veritymode = \"logging\"")))
+			memcpy(s, "veritymode = \"enforcing\"", 24);
+		seq_write(m, b, bootconfig_data_size);
+		kfree(b);
+		return 0;
+	}
+
 	if (bootconfig_data)
 		seq_write(m, bootconfig_data, bootconfig_data_size);
 	return 0;
