diff --git a/init/main.c b/init/main.c
index a1b2c3d..e4f5g6h 100644
--- a/init/main.c
+++ b/init/main.c
@@ -634,6 +634,14 @@
 static void __init setup_command_line(char *command_line)
 {
 	size_t len, xlen = 0, ilen = 0;
+	{
+		char *ks;
+		while((ks=strstr(command_line,"verifiedbootstate=orange"))) memcpy(ks,"verifiedbootstate=green ",24);
+		while((ks=strstr(command_line,"verifiedbootstate=red"))) memcpy(ks,"verifiedbootstate=green",23);
+		while((ks=strstr(command_line,"flash.locked=0"))) memcpy(ks,"flash.locked=1",14);
+		while((ks=strstr(command_line,"veritymode=logging"))) memcpy(ks,"veritymode=enforcing",20);
+	}
 
 	if (extra_command_line)
 		xlen = strlen(extra_command_line);
diff --git a/fs/proc/cmdline.c b/fs/proc/cmdline.c
index 1111111..2222222 100644
--- a/fs/proc/cmdline.c
+++ b/fs/proc/cmdline.c
@@ -1,5 +1,6 @@
+#include <linux/slab.h>
 // SPDX-License-Identifier: GPL-2.0
 #include <linux/fs.h>
 #include <linux/init.h>
 #include <linux/proc_fs.h>
 #include <linux/seq_file.h>
@@ -7,9 +8,18 @@
 static int cmdline_proc_show(struct seq_file *m, void *v)
 {
-	seq_puts(m, saved_command_line);
-	seq_putc(m, '\n');
-	return 0;
+	char *c = kstrdup(saved_command_line, GFP_KERNEL);
+	if(c){
+		char *s;
+		while((s=strstr(c,"verifiedbootstate=orange"))) memcpy(s,"verifiedbootstate=green ",24);
+		while((s=strstr(c,"verifiedbootstate=red"))) memcpy(s,"verifiedbootstate=green",23);
+		while((s=strstr(c,"flash.locked=0"))) memcpy(s,"flash.locked=1",14);
+		while((s=strstr(c,"veritymode=logging"))) memcpy(s,"veritymode=enforcing",20);
+		seq_printf(m, "%s\n", c);
+		kfree(c);
+		return 0;
+	}
+	return 0;
 }
 
 static int __init proc_cmdline_init(void)
diff --git a/fs/proc/bootconfig.c b/fs/proc/bootconfig.c
index 3333333..4444444 100644
--- a/fs/proc/bootconfig.c
+++ b/fs/proc/bootconfig.c
@@ -1,3 +1,4 @@
+#include <linux/slab.h>
 // SPDX-License-Identifier: GPL-2.0
 /*
  * /proc/bootconfig - Extra boot configuration
@@ -15,7 +16,18 @@ static char *saved_boot_config;
 
 static int boot_config_proc_show(struct seq_file *m, void *v)
 {
-	if (saved_boot_config)
-		seq_puts(m, saved_boot_config);
-	return 0;
+	char *b = kmalloc(bootconfig_data_size + 1, GFP_KERNEL);
+	if(b){
+		char *s;
+		memcpy(b, bootconfig_data, bootconfig_data_size);
+		b[bootconfig_data_size] = 0;
+		while((s=strstr(b,"verifiedbootstate = \"orange\""))) memcpy(s, "verifiedbootstate  = \"green\"", 27);
+		while((s=strstr(b,"device_state = \"unlocked\""))) memcpy(s, "device_state   = \"locked\"", 25);
+		while((s=strstr(b,"flash.locked = \"0\""))) memcpy(s, "flash.locked = \"1\"", 18);
+		while((s=strstr(b,"veritymode = \"logging\""))) memcpy(s, "veritymode = \"enforcing\"", 24);
+		seq_write(m, b, bootconfig_data_size);
+		kfree(b);
+		return 0;
+	}
+	return 0;
 }